<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="fdu.kaoyanrank.mapper.UserMapper">

    <resultMap id="ResultMap" type="fdu.kaoyanrank.entity.User">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="exam_no_hash" property="examNoHash" jdbcType="CHAR"/>
        <result column="id_card_hash" property="idCardHash" jdbcType="CHAR"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="findByExamNoHashAndIdCardHash" resultMap="ResultMap">
        SELECT
        id, exam_no_hash, id_card_hash, role, status, created_at, updated_at
        FROM user
        WHERE exam_no_hash = #{examNoHash} OR id_card_hash = #{idCardHash}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="fdu.kaoyanrank.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (exam_no_hash, id_card_hash, role, status, created_at, updated_at)
        VALUES (#{examNoHash}, #{idCardHash}, #{role}, #{status}, NOW(), NOW())
    </insert>

</mapper>
